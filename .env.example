# API
API_KEY=change-me-to-a-long-random-string
HOST=127.0.0.1
PORT=8000
DEV_UI_ENABLED=true

# Whisper
WHISPER_MODEL=small
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=pt

# Limits
MAX_FILE_SIZE_MB=50
MAX_DURATION_MINUTES=60
MAX_PROCESSING_MINUTES=45
MAX_JOBS_PER_MINUTE=10
MAX_CONCURRENT_JOBS=1

# Queue (local SQLite — job state before/during processing)
QUEUE_DB_PATH=./data/queue.db
TEMP_DIR=./data/tmp

# Supabase (optional — metrics work without it if SAVE_METRICS=false)
SUPABASE_URL=https://your-project.supabase.co
# Accepts SUPABASE_SERVICE_KEY or SUPABASE_SERVICE_ROLE_KEY
SUPABASE_SERVICE_KEY=your-service-role-key

# Logging / recovery
LOG_LEVEL=INFO
STALE_JOB_MINUTES=10

# Privacy / LGPD flags
SAVE_AUDIO=false
SAVE_TRANSCRIPT=false
SAVE_METRICS=true

# Local dev: set SAVE_METRICS=false if Supabase is not configured yet
